{
  "name": "serve-android",
  "version": "0.2.1",
  "description": "Android device control and streaming via web interface",
  "type": "module",
  "bin": {
    "serve-android": "./bin/serve-android.js"
  },
  "workspaces": [
    "server",
    "client",
    "shared"
  ],
  "scripts": {
    "setup": "bash scripts/setup.sh",
    "dev": "concurrently \"bun run --cwd server dev\" \"bun run --cwd client dev\"",
    "build": "bun run --cwd server build && bun run --cwd client build",
    "build:client": "bun run --cwd client build",
    "start:prod": "bun run --cwd server start",
    "type-check": "tsc --noEmit --workspaceRoot"
  },
  "keywords": [
    "android",
    "device",
    "streaming",
    "control",
    "adb",
    "remote"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nmiz1987/serve-device"
  },
  "bugs": {
    "url": "https://github.com/nmiz1987/serve-device/issues"
  },
  "homepage": "https://github.com/nmiz1987/serve-device",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "typescript": "^5.3.3"
  }
}
